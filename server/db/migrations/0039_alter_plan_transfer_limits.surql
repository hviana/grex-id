DEFINE FIELD maxConcurrentDownloads ON plan TYPE int DEFAULT 0;
DEFINE FIELD maxConcurrentUploads   ON plan TYPE int DEFAULT 0;
DEFINE FIELD maxDownloadBandwidthMB ON plan TYPE float DEFAULT 0;
DEFINE FIELD maxUploadBandwidthMB   ON plan TYPE float DEFAULT 0;
DEFINE FIELD maxOperationCount      ON plan TYPE int DEFAULT 0;
