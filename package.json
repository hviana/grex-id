{
  "name": "grex-id",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dev:vinext": "vite dev --port 3001",
    "build:vinext": "vite build",
    "db:setup": "tsx server/db/setup.ts",
    "db:migrate": "tsx -e \"import('./server/db/migrations/runner').then(m => m.runMigrations()).then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\"",
    "db:seed": "tsx -e \"import('./server/db/seeds/runner').then(m => m.runSeeds()).then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\""
  },
  "dependencies": {
    "@hviana/surreal-fs": "npm:@jsr/hviana__surreal-fs@^1.0.1",
    "@panva/jose": "npm:@jsr/panva__jose@^6.2.2",
    "chart.js": "^4.5.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "surrealdb": "^2.0.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-rsc": "^0.5.21",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "react-server-dom-webpack": "^19.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vinext": "^0.0.41",
    "vite": "^8.0.3"
  },
  "type": "module"
}
